# Base de données
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://oracle:changeme_strong_password@postgres:5432/oracle_messenger

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=changeme_jwt_secret_very_long_random_string

# NextAuth
NEXTAUTH_URL=https://messenger.oracle-plus.online
NEXTAUTH_SECRET=changeme_nextauth_secret

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URLs
FRONTEND_URL=https://messenger.oracle-plus.online
BACKEND_URL=https://api-messenger.oracle-plus.online
NEXT_PUBLIC_BACKEND_URL=https://api-messenger.oracle-plus.online

# VAPID (générer avec: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# OpenAI
OPENAI_API_KEY=sk-your_openai_key
