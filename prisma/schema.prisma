generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String?
  messages Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  chatRoom  ChatRoom @relation(fields: [chatRoomId], references: [id])
  chatRoomId Int
}

model ChatRoom {
  id       Int      @id @default(autoincrement())
  name     String
  messages Message[]
}
