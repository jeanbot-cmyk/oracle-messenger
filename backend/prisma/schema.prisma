generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  googleId    String   @unique
  email       String   @unique
  name        String
  username    String   @unique
  avatar      String?
  status      String   @default("offline")
  lastSeen    DateTime?
  isPremium   Boolean  @default(false)
  premiumUntil DateTime?
  bio         String?
  phone       String?  @unique  // Format international nettoyé : +225XXXXXXXX
  pushToken   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sentMessages     Message[]      @relation("SentMessages")
  participations   Participant[]
  aiMemories       AiMemory[]
  stories          Story[]
  storyViews       StoryView[]
  callLogs         CallLog[]
}

// Historique des appels persisté en base
model CallLog {
  id             String   @id @default(uuid())
  callId         String   // identifiant de session WebRTC
  userId         String   // utilisateur concerné par cette entrée
  peerId         String   // l'autre participant
  peerName       String
  type           String   // audio | video
  direction      String   // incoming | outgoing | missed
  duration       Int?     // secondes, null si manqué/refusé
  startedAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
}

model Conversation {
  id           String   @id @default(uuid())
  type         String   @default("direct") // direct | group
  name         String?
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participants Participant[]
  messages     Message[]
}

model Participant {
  id             String       @id @default(uuid())
  userId         String
  conversationId String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  type           String   @default("text")
  status         String   @default("sent")
  replyToId      String?
  isDeleted      Boolean  @default(false)
  isEdited       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  replyTo        Message?     @relation("Replies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("Replies")
}

// Stories — visibles 24h, partagées entre utilisateurs
model Story {
  id          String   @id @default(uuid())
  authorId    String
  content     String   @db.Text  // base64 image ou texte
  caption     String?
  type        String   @default("text") // text | image
  bg          String   @default("#128C7E")
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  views       StoryView[]
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  viewedAt  DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([storyId, userId])
}

// Mémoire IA — 7 jours conversations, 1 mois global
model AiMemory {
  id        String   @id @default(uuid())
  userId    String
  type      String   // conversation | global
  content   String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
